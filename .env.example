# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Instagram / Meta App
# This app uses "Instagram API with Instagram Login" (Business Login) — NOT Instagram
# Basic Display and NOT Facebook Login. Dashboard: https://developers.facebook.com/apps/
#   -> Your App -> Instagram -> API setup with Instagram business login
#
# App ID / secret: use the *Instagram app ID* and *Instagram app secret* shown on that
# Instagram product page — NOT the parent Meta app ID from Settings -> Basic.
NEXT_PUBLIC_INSTAGRAM_APP_ID=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
# Optional: parent Meta app secret (Settings -> Basic). Only needed if webhook signature
# validation fails with 401s because Meta signs deliveries with the parent app secret.
META_APP_SECRET=
# Must exactly match one of the "OAuth redirect URIs" in Instagram -> Business login settings
# (character-for-character: scheme, host, path, no trailing slash mismatch).
NEXT_PUBLIC_INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/instagram/callback
# Any random string; enter the same value in the webhook subscription form in the dashboard.
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=
